# Security headers for static hosts that read a _headers file (Cloudflare Pages,
# Netlify). Copied verbatim into ./out at build. On Nginx/Apache, set the
# equivalent headers in the server config instead.
#
# The Content-Security-Policy below is intentionally compatible with this site:
#  - 'unsafe-inline' for script/style is required because a static export
#    inlines its hydration scripts and font/style tags (no server nonce exists).
#  - connect-src allows the Web3Forms contact-form endpoint and Cloudflare Web
#    Analytics (cloudflareinsights.com); script-src allows its injected beacon.
#  - frame-src allows the Google Maps embed on the Contact/About pages.
#  - worker-src blob: + script-src 'wasm-unsafe-eval' blob: let the /admin photo
#    uploader convert iPhone HEIC photos in a WASM Web Worker (heic-to).
# Tighten further only if you remove those integrations.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob: https://static.cloudflareinsights.com; worker-src 'self' blob:; connect-src 'self' https://api.web3forms.com https://cloudflareinsights.com blob: data:; frame-src https://www.google.com https://maps.google.com; form-action 'self' https://api.web3forms.com
